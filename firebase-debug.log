[debug] [2026-05-06T02:40:31.311Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/share-it-9a030/rulesets {"name":"projects/share-it-9a030/rulesets/203b9282-189b-4da6-a46a-bf0adfc84f7f","source":{"files":[{"content":"rules_version = '2';\nservice firebase.storage {\n  match /b/{bucket}/o {\n    function isAuthenticated() {\n      return request.auth != null;\n    }\n\n    function isImage() {\n      return request.resource != null\n        && request.resource.size < 8 * 1024 * 1024\n        && request.resource.contentType.matches('image/.*');\n    }\n\n    function ownsPhone(phone) {\n      return isAuthenticated()\n        && request.auth.token.phone_number == '+91' + phone;\n    }\n\n    match /drivers/{phone}/{uid}/{fileName} {\n      allow read: if isAuthenticated() && (request.auth.uid == uid || ownsPhone(phone));\n      allow write: if isAuthenticated()\n        && request.auth.uid == uid\n        && ownsPhone(phone)\n        && isImage();\n    }\n\n    match /driver_photos/{uid}/{fileName} {\n      allow read: if isAuthenticated();\n      allow write: if isAuthenticated()\n        && request.auth.uid == uid\n        && isImage();\n    }\n  }\n}\n","name":"storage.rules"}]},"createTime":"2026-05-07T11:08:11.672559Z","metadata":{"services":["firebase.storage"]}}
