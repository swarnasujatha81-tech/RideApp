[debug] [2026-05-06T02:40:35.373Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/share-it-9a030/rulesets {"name":"projects/share-it-9a030/rulesets/ae863fde-e9ab-4856-b1f1-e6c142e98d8c","source":{"files":[{"content":"rules_version = '2';\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n\r\n    function isAuthenticated() {\n      return request.auth != null;\n    }\n\n    function ownsPhoneDocument(driverId) {\n      return isAuthenticated() && request.auth.token.phone_number == '+91' + driverId;\n    }\n\r\n    // Users collection\r\n    match /users/{userId} {\r\n      allow read, write: if isAuthenticated() && request.auth.uid == userId;\r\n    }\r\n\r\n    // Drivers collection: ownership via activeAuthUid\r\n    match /drivers/{driverId} {\n      // Read (get/listen): owner or non-existing (for existence check)\n      allow read: if isAuthenticated() && (\n        !resource.exists ||\n        resource.data.activeAuthUid == request.auth.uid ||\n        ownsPhoneDocument(driverId)\n      );\n      // Create: activeAuthUid must match requester\n      allow create: if isAuthenticated() && (\n        request.resource.data.activeAuthUid == request.auth.uid ||\n        ownsPhoneDocument(driverId)\n      );\n      // Update: existing activeAuthUid must match\n      allow update: if isAuthenticated() && (\n        resource.data.activeAuthUid == request.auth.uid ||\n        ownsPhoneDocument(driverId)\n      );\n      allow delete: if false;\n    }\n\r\n    // Rides collection: read open to authenticated users; writes restricted to participants\r\n    match /rides/{rideId} {\r\n      // Read: any authenticated user (app needs collection-wide listener)\r\n      allow read: if isAuthenticated();\r\n      // Create: passenger or shared passenger\r\n      allow create: if isAuthenticated() && (\r\n        request.resource.data.passengerId == request.auth.uid ||\r\n        (request.resource.data.sharedPassengerIds is list && request.auth.uid in request.resource.data.sharedPassengerIds)\r\n      );\r\n      // Update: passenger, driver, or shared passenger\r\n      allow update: if isAuthenticated() && (\r\n        resource.data.passengerId == request.auth.uid ||\r\n        resource.data.driverId == request.auth.uid ||\r\n        (resource.data.sharedPassengerIds is list && request.auth.uid in resource.data.sharedPassengerIds)\r\n      );\r\n      // Delete: passenger or driver only\r\n      allow delete: if isAuthenticated() && (\r\n        resource.data.passengerId == request.auth.uid ||\r\n        resource.data.driverId == request.auth.uid\r\n      );\r\n    }\r\n\r\n    // Ride messages subcollection under a ride\r\n    match /rides/{rideId}/messages/{messageId} {\r\n      // Allow read/write if user is passenger or driver of the parent ride\r\n      allow read, write: if isAuthenticated() && (\r\n        get(/databases/$(database)/documents/rides/$(rideId)).data.passengerId == request.auth.uid ||\r\n        get(/databases/$(database)/documents/rides/$(rideId)).data.driverId == request.auth.uid\r\n      );\r\n    }\r\n\r\n    // Ride history: both passenger and driver can access their entries\r\n    match /rideHistory/{historyId} {\r\n      // Read\r\n      allow read: if isAuthenticated() && (\r\n        resource.data.passengerId == request.auth.uid ||\r\n        resource.data.driverId == request.auth.uid\r\n      );\r\n      // Create\r\n      allow create: if isAuthenticated() && (\r\n        request.resource.data.passengerId == request.auth.uid ||\r\n        request.resource.data.driverId == request.auth.uid\r\n      );\r\n      // Update/Delete\r\n      allow update, delete: if isAuthenticated() && (\r\n        resource.data.passengerId == request.auth.uid ||\r\n        resource.data.driverId == request.auth.uid\r\n      );\r\n    }\r\n\r\n    // Help forum\r\n    match /helpForum/{questionId} {\r\n      allow read: if isAuthenticated();\r\n      allow create: if isAuthenticated() && request.resource.data.askedByEmail == request.auth.token.email;\r\n      allow update: if isAuthenticated() && (\r\n        resource.data.askedByEmail == request.auth.token.email ||\r\n        request.auth.token.firebase.sign_in_provider == 'custom'\r\n      );\r\n      allow delete: if false;\r\n    }\r\n\r\n    // Ride ratings\r\n    match /rideRatings/{ratingId} {\r\n      allow read: if isAuthenticated() && (\r\n        resource.data.passengerId == request.auth.uid ||\r\n        resource.data.driverId == request.auth.uid\r\n      );\r\n      allow create: if isAuthenticated() && (\r\n        request.resource.data.passengerId == request.auth.uid ||\r\n        request.resource.data.driverId == request.auth.uid\r\n      );\r\n      allow update, delete: if false;\r\n    }\r\n\r\n    // Driver reports\r\n    match /driverReports/{reportId} {\r\n      allow read: if isAuthenticated() && (\r\n        resource.data.passengerId == request.auth.uid ||\r\n        resource.data.driverId == request.auth.uid\r\n      );\r\n      allow create: if isAuthenticated() && (\r\n        request.resource.data.passengerId == request.auth.uid ||\r\n        request.resource.data.driverId == request.auth.uid\r\n      );\r\n      allow update, delete: if false;\r\n    }\r\n\r\n    // Earnings withdrawals\r\n    match /earnWithdrawals/{withdrawalId} {\r\n      allow read: if isAuthenticated() && resource.data.driverId == request.auth.uid;\r\n      allow create: if isAuthenticated() && request.resource.data.driverId == request.auth.uid;\r\n      allow update, delete: if isAuthenticated() && resource.data.driverId == request.auth.uid;\r\n    }\r\n\r\n    // ShareAuto pools\r\n    match /shareAutoPools/{poolId} {\r\n      // Read: owner (passenger) or any driver when pool is searching\r\n      allow read: if isAuthenticated() && (\r\n        resource.data.passengerId == request.auth.uid ||\r\n        resource.data.status == 'searching'\r\n      );\r\n      // Create: passenger only\r\n      allow create: if isAuthenticated() && request.resource.data.passengerId == request.auth.uid;\r\n      // Delete: owner (passenger) only\r\n      allow delete: if isAuthenticated() && resource.data.passengerId == request.auth.uid;\r\n      allow update: if false;\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-05-07T11:08:15.733103Z","metadata":{"services":["cloud.firestore"]}}
